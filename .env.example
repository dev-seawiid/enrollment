# [Auth.js] 보안 및 암호화 설정 (npx auth secret으로 생성)
# 쿠키 암호화 및 세션 관리를 위한 마스터 키 (유출 주의)
AUTH_SECRET=jsD82... 

# [Auth.js] 배포 환경 신뢰 설정
# Vercel 외 환경(Docker, 로컬 등)에서 호스트 이름 불일치 에러 방지
AUTH_TRUST_HOST=true

# [Auth.js] 기본 인증 URL
# 프로젝트의 절대 경로 (예: http://localhost:3000)
AUTH_URL=http://localhost:3000

# [Backend API] 서버 전용 설정 (보안 강화)
# 브라우저에 노출되지 않으며, auth.ts 및 서버 컴포넌트에서만 접근 가능
API_BASE_URL=http://localhost:8080/api

# [Development] Mock 서비스 워커 설정
# 개발 환경에서 API 모킹(Mocking) 활성화 여부 (true/false)
NEXT_PUBLIC_MSW_ENABLED=true